# ═══════════════════════════════════════════════════
# MailAI Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Required ──────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Your Details (used in draft signatures) ───────
YOUR_NAME=Your Full Name
YOUR_PHONE=+1 234 567 890
YOUR_EMAIL=your@email.com
YOUR_LINKEDIN=linkedin.com/in/yourprofile

# ── Agent Behavior ────────────────────────────────
SCAN_DAYS=1                          # How many days of emails to scan
POLL_INTERVAL_MINUTES=180            # Daemon frequency (180 = every 3 hours)
GMAIL_OAUTH_LOCAL_PORT=8080          # First-time Docker OAuth callback port
GMAIL_OAUTH_PUBLIC_HOST=localhost    # OAuth redirect host shown to Google
PUBLIC_BASE_URL=                    # Railway: set to https://<your-app>.up.railway.app

# Optional: paste full OAuth client JSON (same as config/credentials.json) for Docker when file is not mounted
# GMAIL_CREDENTIALS_JSON={"installed":{...}}
# Optional: base64-encoded token.pickle for hosted bootstrap when file restore is unavailable
# GMAIL_TOKEN_PICKLE_B64=

# ── State persistence (Railway Bucket / S3-compatible) ────────────────
# If your host doesn't support persistent volumes, you can persist token.pickle to an S3-compatible bucket.
# Railway Buckets usually provide these values in the UI; add them as service variables.
MAILAI_STATE_S3_ENABLED=false
MAILAI_STATE_S3_ENDPOINT_URL=
MAILAI_STATE_S3_BUCKET=
MAILAI_STATE_S3_PREFIX=mailai
# Uses standard AWS vars for auth:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=auto

# ── Ollama (Local AI — optional) ──────────────────
USE_OLLAMA=false                     # Set to 'true' to try local Ollama first
OLLAMA_MODEL=llama3                  # Model to use from Ollama
OLLAMA_BASE_URL=http://localhost:11434

# ── Backfill (1-year labeling) ────────────────────
# Run: python backfill.py
# Defaults are conservative to avoid crashes and rate limits.
BACKFILL_DAYS=365
BACKFILL_START_DATE=                  # Optional explicit start date (YYYY-MM-DD), overrides BACKFILL_DAYS
BACKFILL_END_DATE=                    # Optional explicit end date (YYYY-MM-DD), defaults to today
BACKFILL_WINDOW_DAYS=7
BACKFILL_MAX_PER_WINDOW=200
BACKFILL_SLEEP_SECONDS=1.5
# Set to true only if you intentionally want Groq during backfill (default: Ollama only, overrides USE_OLLAMA in .env)
# BACKFILL_ALLOW_GROQ=false
# Force no drafts + Ollama-only during backfill
DISABLE_DRAFTS=true
REQUIRE_OLLAMA=true

# ── Token Optimization ────────────────────────────
# Reduce prompt payload sizes to lower daily LLM token burn.
CLASSIFY_MAX_CHARS=900
DRAFT_CONTEXT_MAX_CHARS=2200
